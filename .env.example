# Site login (optional — leave blank to disable the login gate)
VITE_AUTH_USERNAME=your_username_here
VITE_AUTH_PASSWORD=your_password_here

# Airtable credentials
# Get your Personal Access Token from: https://airtable.com/create/tokens
# Your Base ID is in the URL: https://airtable.com/appXXXXXXXXXXXXXX/...
VITE_AIRTABLE_API_KEY=your_personal_access_token_here
VITE_AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Table names in your Airtable base (update these to match your actual table names)
# VITE_AIRTABLE_SALES_TABLE=Sales
# VITE_AIRTABLE_RECRUITER_TABLE=Recruiters

# Marketing — Airtable bases (two separate bases)
VITE_AIRTABLE_CLIENTS_BASE_ID=appVEGUse449LuZpZ
VITE_AIRTABLE_CANDIDATES_BASE_ID=appa05OOLs3y4DF14

# Marketing — Meta Ads API
VITE_META_TOKEN=your_meta_ads_token_here
